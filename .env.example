# Pull from Vercel after connecting an AWS database integration:
#   vercel env pull .env.local
#
# Vercel may prefix vars (e.g. beamxweb_*); lib/env-keys.js reads all aliases.
# If PGHOST is set, contact form uses Aurora/RDS Postgres (IAM auth).
# Otherwise it falls back to DynamoDB when DYNAMODB_TABLE_NAME is set.

AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT:role/Vercel/access-role

# Aurora PostgreSQL (Vercel Marketplace — preferred when PGHOST is present)
PGHOST=your-cluster.region.rds.amazonaws.com
PGPORT=5432
PGUSER=your_iam_db_user
PGDATABASE=postgres

# DynamoDB fallback
DYNAMODB_TABLE_NAME=aws-dynamodb-champagne-window
DYNAMODB_TABLE_PARTITION_KEY=PK
DYNAMODB_TABLE_SORT_KEY=SK

# Or integration-prefixed (from Vercel marketplace), e.g.:
# beamxweb_AWS_REGION=us-east-1
# beamxweb_AWS_ROLE_ARN=arn:aws:iam::...
# beamxweb_PGHOST=....rds.amazonaws.com
# beamxweb_PGUSER=postgres
