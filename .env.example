# Pull from Vercel after connecting the DynamoDB integration:
#   vercel env pull .env.local
#
# The integration may use SPACEKAYSONKELLY_* names; the API reads both.

AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT:role/Vercel/access-dynamodb-champagne-window
DYNAMODB_TABLE_NAME=aws-dynamodb-champagne-window
DYNAMODB_TABLE_PARTITION_KEY=PK
DYNAMODB_TABLE_SORT_KEY=SK

# Or prefixed (from Vercel marketplace):
# SPACEKAYSONKELLY_AWS_REGION=us-east-1
# SPACEKAYSONKELLY_AWS_ROLE_ARN=arn:aws:iam::...
# SPACEKAYSONKELLY_DYNAMODB_TABLE_NAME=aws-dynamodb-champagne-window
# SPACEKAYSONKELLY_DYNAMODB_TABLE_PARTITION_KEY=PK
# SPACEKAYSONKELLY_DYNAMODB_TABLE_SORT_KEY=SK
